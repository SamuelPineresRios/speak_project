# ===============================================
# EVALUATION SERVICE - Environment Template
# ===============================================
# Copy this to .env and fill with your values

# Anthropic API Key for LLM document evaluations
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API Key for audio mission conversations
# Get it from: https://openrouter.io/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter Model Selection
# Recommended: openai/gpt-4-turbo-preview or anthropic/claude-opus
OPENROUTER_MODEL=openai/gpt-4-turbo-preview

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS Configuration
ALLOWED_ORIGIN=http://localhost:3000

# Service Configuration
EVALUATION_SERVICE_URL=http://127.0.0.1:8000
LOG_LEVEL=info
NODE_ENV=development
