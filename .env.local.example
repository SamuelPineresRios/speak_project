# ===============================================
# VOX - LOCAL DEVELOPMENT ENVIRONMENT
# ===============================================
# Copy this to .env.local and update with your values
# .env.local is in .gitignore and NOT tracked by git
# This is the recommended way to handle local development secrets

# API KEYS & EXTERNAL SERVICES
ANTHROPIC_API_KEY=sk-ant-v1-your-actual-key-here
OPENROUTER_API_KEY=sk-or-v1-your-actual-key-here

# AUTHENTICATION & SECURITY
JWT_SECRET=my-local-jwt-secret-32-characters-minimum
NODE_ENV=development

# DATABASE & CACHE
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# FRONTEND CONFIGURATION
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# BACKEND SERVICE CONFIGURATION
EVALUATION_SERVICE_URL=http://localhost:8000
ALLOWED_ORIGIN=http://localhost:3000

# WEBHOOKS & EXTERNAL INTEGRATIONS
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/activity-completed

# ADMIN & MONITORING
ADMIN_EMAILS=youremail@example.com
LOG_LEVEL=debug
