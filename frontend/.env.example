# JWT Secret — cambiar en producción (mínimo 32 caracteres)
JWT_SECRET=vox-dev-secret-change-in-production-32chars

# Evaluation Service (FastAPI)
EVALUATION_SERVICE_URL=http://localhost:8000

# Admin metrics access (emails separados por coma)
ADMIN_EMAILS=admin@vox.app

# NODE_ENV
NODE_ENV=development
