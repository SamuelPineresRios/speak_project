# ===============================================
# SPEAK MVP - Environment Configuration Template
# ===============================================
# This file serves as a template for developers.
# Copy this to .env.local and fill in with YOUR values.
# NEVER commit .env or .env.local to version control!

# ===============================================
# API KEYS & EXTERNAL SERVICES
# ===============================================

# Anthropic API Key (for evaluation service)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API Key (for AI chat and tutoring)
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===============================================
# AUTHENTICATION & SECURITY
# ===============================================

# JWT Secret for session management
# Use a strong, random string of 32+ characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secure-random-string-of-32-plus-characters

# Node environment (development | staging | production)
NODE_ENV=development

# ===============================================
# DATABASE & CACHE
# ===============================================

# Redis Cache Server
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===============================================
# FRONTEND CONFIGURATION
# ===============================================

# Frontend base URL for API calls
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ===============================================
# BACKEND SERVICE CONFIGURATION
# ===============================================

# Evaluation Service URL (FastAPI backend)
EVALUATION_SERVICE_URL=http://localhost:8000

# Allowed origins for CORS
ALLOWED_ORIGIN=http://localhost:3000

# ===============================================
# WEBHOOKS & EXTERNAL INTEGRATIONS
# ===============================================

# N8N Webhook URL for activity tracking
# Get from your N8N instance
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/activity

# ===============================================
# ADMIN & MONITORING
# ===============================================

# Admin email addresses (comma-separated)
ADMIN_EMAILS=admin@speak.app,support@speak.app

# Logging level (debug | info | warn | error)
LOG_LEVEL=info
